            "method": "PUT",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{}" },
            "url": { "raw": "{{base_url}}/api/v1/microgrid/{{instance_id}}/topology", "host": ["{{base_url}}"], "path": ["api", "v1", "microgrid", "{{instance_id}}", "topology"] }
          }
        },
        {
          "name": "GET /microgrid/{id}/dashboard - 实时仪表盘",
          "request": {
