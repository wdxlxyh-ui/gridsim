            "body": {
              "mode": "raw",
              "raw": "{\n  \"csv_file\": \"point.csv\",\n  \"time_format\": \"relative\",\n  \"time_unit\": \"ms\",\n  \"mappings\": [\n    { \"column\": 1, \"ioa\": 1 },\n    { \"column\": 2, \"ioa\": 2 }\n  ]\n}"
            },
            "url": { "raw": "{{base_url}}/api/v1/instances/{{instance_id}}/csv-replay", "host": ["{{base_url}}"], "path": ["api", "v1", "instances", "{{instance_id}}", "csv-replay"] }
          }
