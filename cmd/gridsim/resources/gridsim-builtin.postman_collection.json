          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{base_url}}/api/v1/microgrid/{{instance_id}}/control/{{device_id}}?closed=true",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "microgrid", "{{instance_id}}", "control", "{{device_id}}"],
