    {
      "name": "获取 Token",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "var moment = require('moment');",
              "var ts = moment().valueOf();",
              "var app_key = pm.environment.get('app_key');",
              "var app_secret = pm.environment.get('app_secret');",
              "var origin = app_key + ts + app_secret;",
              "var token_encry = CryptoJS.SHA256(origin).toString().toLowerCase();",
              "pm.environment.set('encryption', token_encry);",
              "pm.environment.set('appKey', app_key);",
              "pm.environment.set('genTs', ts);"
            ],
            "type": "text/javascript"
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "var data = JSON.parse(responseBody);",
              "if (data.data && data.data.accessToken) {",
              "    pm.environment.set('access_token', data.data.accessToken);",
              "    console.log('Token saved:', data.data.accessToken.substring(0,20) + '...');",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\"appKey\": \"{{appKey}}\", \"encryption\": \"{{encryption}}\", \"timestamp\": \"{{genTs}}\"}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{token_url}}",
          "host": [
            "{{token_url}}"
          ]
        }
      },
      "response": []
    }
